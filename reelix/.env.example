# ── Reelix environment variables ──────────────────────────────
# Copy this file to ".env" and fill in your keys.

# OpenAI API key — powers AI ad copy generation (headlines, hooks, etc.)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# fal.ai API key — powers AI text-to-video generation
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=

# (Optional) Override the text-to-video model.
# Browse models at https://fal.ai/models?categories=text-to-video
FAL_VIDEO_MODEL=fal-ai/kling-video/v1.6/standard/text-to-video
